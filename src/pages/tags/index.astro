---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPost from "../../components/BlogPost.astro";

// Load all posts
const allPosts = await Astro.glob("../posts/*.md");

// Collect unique, alphabetically sorted tags
const tags = [
    ...new Set(allPosts.map((post) => post.frontmatter.tags).flat()),
].sort();

// Build an array of { tag, posts[] }
const postsByTag = tags.map((tag) => ({
    tag,
    posts: allPosts.filter((post) => post.frontmatter.tags.includes(tag)),
}));

const pageTitle = "Tag Index";
---

<BaseLayout pageTitle={pageTitle}>
    <h2>All Tags</h2>
    <div class="tags">
        {
            tags.map((tag) => (
                <p class="tag">
                    <a href={`/tags/${tag}`}>{tag}</a>
                </p>
            ))
        }
    </div>

    <h2>Posts by Tag</h2>

    {
        postsByTag.map(({ tag, posts }) => (
            <section class="tag-section">
                <h3>{tag}</h3>
                <ul class="blogpost_list">
                    {posts.map((post) => (
                        <BlogPost
                            url={post.url}
                            title={post.frontmatter.title}
                            pubDate={post.frontmatter.pubDate.slice(0, 10)}
                            image={post.frontmatter.image}
                        />
                    ))}
                </ul>
            </section>
        ))
    }
</BaseLayout>
